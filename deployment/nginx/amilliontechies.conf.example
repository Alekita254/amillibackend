server {
    listen 80;
    server_name amilliontechies.com www.amilliontechies.com;
    root /var/www/projects/amilliontechies/frontend/dist;
    index index.html;

    location / {
        try_files $uri $uri/ /index.html;
    }

    location /static/ {
        alias /var/www/projects/amilliontechies/backend/staticfiles/;
        expires 1y;
        access_log off;
    }

    location /media/ {
        alias /var/www/projects/amilliontechies/backend/media/;
        expires 1y;
        access_log off;
    }
}

server {
    listen 80;
    server_name millibackend.amilliontechies.com;

    location /static/ {
        alias /var/www/projects/amilliontechies/backend/staticfiles/;
        expires 1y;
        access_log off;
    }

    location /media/ {
        alias /var/www/projects/amilliontechies/backend/media/;
        expires 1y;
        access_log off;
    }

    location / {
        proxy_pass http://127.0.0.1:8000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
